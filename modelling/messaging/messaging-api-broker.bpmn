    <bpmn:textAnnotation id="TextAnnotation_1txo539">
      <bpmn:text>CallActivity Type: BPMN
Called Element: Process_C</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1unancf">
      <bpmn:text>Exemplary asynchronous callback with REST:
POST /message/{tenantId}/{messageName}/{businessKey}/
{
     "dataC": "This is updated data c",
     "aVariable": "This is from µService",
     "anotherVariable": true,
     "dataNr": 200
}</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1nn6p7e">
      <bpmn:text>Instantiation with REST:
POST /message/{tenantId}/{messageName}/
{
    "dataA", "This is data a"
}</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1rk35k0">
